# ===========================================================================
# News Trading System — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in the values.
#   cp .env.template .env

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
NEWSAPI_KEY=

# ---------------------------------------------------------------------------
# Broker mode: paper_local | alpaca_paper | alpaca_live
# ---------------------------------------------------------------------------
TRADING_MODE=paper_local

# Alpaca API (required for alpaca_paper / alpaca_live modes)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_MODE=paper

# Safety gate — must be "true" to allow alpaca_live
LIVE_TRADING_CONFIRMED=

# ---------------------------------------------------------------------------
# Optional — Reddit social sentiment (via PRAW)
# System works fine without these; Reddit feed is simply skipped and
# NewsAPI + Marketaux weights are automatically increased to compensate.
#
# To obtain Reddit API credentials:
#   1. Go to https://www.reddit.com/prefs/apps
#   2. Click "create another app..." at the bottom
#   3. Choose "script" as the app type
#   4. Fill in name and redirect URI (use http://localhost:8080)
#   5. Copy the client ID (under the app name) and secret
# ---------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=news-trading-bot/1.0

# ---------------------------------------------------------------------------
# Optional — Marketaux (financial news API)
# ---------------------------------------------------------------------------
MARKETAUX_API_TOKEN=

# ---------------------------------------------------------------------------
# Optional — Adanos social sentiment (Reddit + X)
# PERMANENTLY DISABLED — free tier quota is only ~10 requests/day, causes 429s.
# The code path exists but is gated behind this flag.  Do not enable unless
# you have a paid Adanos plan AND have verified quota limits.
# ---------------------------------------------------------------------------
ADANOS_ENABLED=false
ADANOS_API_KEY=

# ---------------------------------------------------------------------------
# Optional — FRED (Federal Reserve Economic Data)
# ---------------------------------------------------------------------------
FRED_API_KEY=

# ---------------------------------------------------------------------------
# Optional — EODHD (German/EU stocks + intraday data)
# On Railway: set EODHD_API_TOKEN in the service variables dashboard
# ---------------------------------------------------------------------------
EODHD_API_TOKEN=

# ---------------------------------------------------------------------------
# Optional — Telegram notifications
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Optional — Dashboard password (leave empty for no auth)
# ---------------------------------------------------------------------------
# DASHBOARD_PASSWORD=

# ---------------------------------------------------------------------------
# Optional — Database path (default: news_trading.db)
# ---------------------------------------------------------------------------
# DB_PATH=news_trading.db
