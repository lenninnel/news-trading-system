[Unit]
Description=NTS daily Polygon OHLC incremental ingest
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/home/trading/news-trading-system
ExecStart=/home/trading/news-trading-system/.venv/bin/python3 /home/trading/news-trading-system/scripts/ingest_ohlc.py --incremental
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
