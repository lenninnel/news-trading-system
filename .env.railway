# ══════════════════════════════════════════════════════════════════════════════
#  .env.railway — Environment variables to set in Railway dashboard
#
#  Go to: Railway Dashboard → Your Project → Your Service → Variables
#  Paste these and fill in the values.
# ══════════════════════════════════════════════════════════════════════════════

# Required — AI & news APIs
ANTHROPIC_API_KEY=
NEWSAPI_KEY=

# Broker — Alpaca API credentials
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_MODE=paper
TRADING_MODE=alpaca_paper

# Safety gate — set to "true" only when ready for real money
LIVE_TRADING_CONFIRMED=

# Dashboard password (leave empty to disable auth)
DASHBOARD_PASSWORD=

# Port — Railway sets this automatically, but you can override
PORT=8501
